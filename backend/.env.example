# Environment
NODE_ENV=development

# Server
PORT=3000
API_PREFIX=api

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/hatod_delivery?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
CORS_ORIGIN=http://localhost:8081,exp://192.168.1.100:8081

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_LOCATION=./uploads

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Legal and Policy Metadata
LEGAL_TERMS_URL=https://hatod.app/terms
LEGAL_PRIVACY_URL=https://hatod.app/privacy
LEGAL_ACCOUNT_DELETION_URL=https://hatod.app/account-deletion
LEGAL_TERMS_VERSION=2026-02-01
LEGAL_PRIVACY_VERSION=2026-02-01
LEGAL_EFFECTIVE_DATE=2026-02-01
LEGAL_SUPPORT_EMAIL=hatodservices@gmail.com
